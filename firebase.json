      },
      {
        "source": "/services/web-app-development",
        "destination": "/services/web-and-app-development-services",
        "type": 301
      },
      {
        "source": "/services/motion-graphics-animation",
        "destination": "/services/motion-graphics",
        "type": 301
      },
      {
        "source": "/services/enterprise-internal-systems",
        "destination": "/services/enterprise-internal-system",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
